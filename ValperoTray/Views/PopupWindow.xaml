<Window x:Class="ValperoTray.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ValperoTray.Views"
        Title="Valpero"
        Width="340" SizeToContent="Height"
        MaxHeight="540"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent">

    <Border Background="{StaticResource BgCardBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Header ────────────────────────────────────────────────── -->
            <Grid Grid.Row="0" Margin="14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" x:Name="StatusDot" Fill="{StaticResource AccentBrush}"
                             VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.7" Color="#22C55E"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="Valpero" FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="RefreshBtn" Style="{StaticResource FlatButton}" Padding="6,4"
                            ToolTip="Refresh" Click="RefreshBtn_Click">
                        <TextBlock Text="↻" FontSize="14" FontWeight="Bold"/>
                    </Button>
                    <Button Style="{StaticResource FlatButton}" Padding="6,4" Margin="4,0,0,0"
                            ToolTip="Settings" Click="SettingsBtn_Click">
                        <TextBlock Text="⚙" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Rectangle Grid.Row="1" Height="1" Fill="{StaticResource BorderBrush}" Margin="0"/>

            <!-- ── Content ───────────────────────────────────────────────── -->
            <ScrollViewer Grid.Row="2" MaxHeight="440" Padding="0,4">
                <StackPanel x:Name="ContentPanel" Margin="0,4"/>
            </ScrollViewer>

            <Rectangle Grid.Row="3" Height="1" Fill="{StaticResource BorderBrush}"/>

            <!-- ── Footer ────────────────────────────────────────────────── -->
            <Grid Grid.Row="3" Margin="14,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LastRefreshLabel" Foreground="{StaticResource Text3Brush}"
                           FontSize="10" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Style="{StaticResource FlatButton}" Padding="6,3"
                        Click="DashboardBtn_Click">
                    <TextBlock Text="Dashboard →" FontSize="11" Foreground="{StaticResource Text3Brush}"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
