<Window x:Class="ValperoTray.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Valpero — Settings"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBaseBrush}"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="⚙" FontSize="16"/>
            <TextBlock Text="Settings" FontSize="16" FontWeight="SemiBold" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- ── API Key section ───────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="16">
            <StackPanel>
                <TextBlock Text="API Key" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock Foreground="{StaticResource Text3Brush}" FontSize="11" TextWrapping="Wrap" Margin="0,10,0,0">
                    Your key is stored securely in Windows Credential Manager, not in any file.
                </TextBlock>

                <!-- Key input -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="KeyBox" Grid.Column="0" PasswordChar="●"/>
                    <Button Grid.Column="2" x:Name="ShowHideBtn" Style="{StaticResource FlatButton}"
                            Padding="10,7" Content="Show" Click="ShowHide_Click"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                </Grid>
                <TextBox x:Name="KeyBoxVisible" Visibility="Collapsed" Margin="0,10,0,0"/>

                <!-- Actions row -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="ValidateBtn" Style="{StaticResource FlatButton}"
                            Padding="12,6" Content="Validate"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Click="Validate_Click"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="ValidationProgress" Text="Validating…" FontSize="11"
                                   Foreground="{StaticResource Text3Brush}" Visibility="Collapsed"/>
                        <TextBlock x:Name="ValidationResult" FontSize="11" Visibility="Collapsed" Margin="6,0,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="3" Style="{StaticResource FlatButton}" Padding="0"
                            Click="GetKey_Click">
                        <TextBlock Text="Get API key →" FontSize="11" Foreground="{StaticResource Text3Brush}"/>
                    </Button>
                </Grid>

                <TextBlock x:Name="SaveError" FontSize="11" Foreground="{StaticResource RedBrush}"
                           TextWrapping="Wrap" Visibility="Collapsed" Margin="0,10,0,0"/>

                <!-- Save / Disconnect row -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="SaveBtn" Style="{StaticResource PrimaryButton}"
                            Content="Save" Click="Save_Click"/>
                    <Button Grid.Column="2" x:Name="DisconnectBtn" Style="{StaticResource FlatButton}"
                            Padding="10,6" Content="Disconnect"
                            Foreground="{StaticResource RedBrush}"
                            Visibility="Collapsed" Click="Disconnect_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Preferences section ───────────────────────────────────────── -->
        <Border Grid.Row="4" Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="16">
            <StackPanel>
                <TextBlock Text="Preferences" FontWeight="SemiBold" FontSize="13"/>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Refresh interval" VerticalAlignment="Center" Foreground="{StaticResource Text2Brush}"/>
                    <ComboBox Grid.Column="1" x:Name="RefreshCombo" Width="130" SelectionChanged="RefreshCombo_Changed">
                        <ComboBoxItem Tag="30"  Content="30 seconds"/>
                        <ComboBoxItem Tag="60"  Content="1 minute" IsSelected="True"/>
                        <ComboBoxItem Tag="120" Content="2 minutes"/>
                        <ComboBoxItem Tag="300" Content="5 minutes"/>
                        <ComboBoxItem Tag="600" Content="10 minutes"/>
                    </ComboBox>
                </Grid>

                <CheckBox x:Name="ShowRtCheck"  Content="Show response time" Checked="Prefs_Changed" Unchecked="Prefs_Changed" Margin="0,12,0,0"/>
                <CheckBox x:Name="ShowUptCheck" Content="Show uptime %" Checked="Prefs_Changed" Unchecked="Prefs_Changed" Margin="0,12,0,0"/>
                <CheckBox x:Name="StartupCheck" Content="Launch at Windows startup" Checked="Startup_Changed" Unchecked="Startup_Changed" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── About ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="6" Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Valpero Tray" FontWeight="SemiBold"/>
                    <TextBlock Text="Version 1.0.0" FontSize="11" Foreground="{StaticResource Text3Brush}"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource FlatButton}" Padding="8,5" Click="Website_Click">
                    <TextBlock Text="valpero.com →" FontSize="11" Foreground="{StaticResource Text3Brush}"/>
                </Button>
            </Grid>
        </Border>

        <!-- Close button -->
        <Button Grid.Row="8" HorizontalAlignment="Right" Style="{StaticResource FlatButton}"
                Padding="16,8" Content="Close" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Click="Close_Click"/>
    </Grid>
</Window>
